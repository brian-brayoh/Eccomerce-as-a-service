# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth.js
# Generate with: npx auth secret
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# ─── Multi-tenancy ────────────────────────────────────────
# The root domain of your platform. Subdomains of this resolve
# to tenants by slug:
#   printcare.yourplatform.com -> Tenant.slug = "printcare"
ROOT_DOMAIN="yourplatform.com"

# For local development on plain "localhost:3000" (no subdomain),
# this tenant is used as the default. Use "printcare.localhost:3000"
# to test a specific tenant by subdomain locally.
DEFAULT_TENANT_SLUG="printcare"

# ─── Vercel Blob (product image uploads) ─────────────────
# Get this from: Vercel dashboard → Storage → Blob → Create/Connect →
# Copy the BLOB_READ_WRITE_TOKEN, or run: vercel env pull
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ─── M-Pesa Daraja (used to build the callback URL) ───────
# Your app's public URL, used to construct the M-Pesa callback
# endpoint (must be HTTPS in production; sandbox often accepts
# any reachable URL including ngrok tunnels for local testing).
NEXT_PUBLIC_APP_URL="https://your-domain.com"
